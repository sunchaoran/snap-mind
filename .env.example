# LLM API Requirements
# LLM Base URL (defaults to MiniMax China: https://api.minimaxi.com/v1)
# LLM_BASE_URL=

LLM_API_KEY=sk-or-xxxxxxxxxxxx

# Obsidian Vault
OBSIDIAN_VAULT_PATH=/Users/sunchaoran/ObsidianVault

# Authentication
API_KEY=sk-snapmind-xxxxxxxxxxxx
JWT_SECRET=your-jwt-secret-here

# Models (optional, defaults shown)
# VLM_MODELS=MiniMax-M2.7
# PROCESSOR_MODEL=MiniMax-M2.7

# Fetch level limit (optional, 1-4, default 4)
# Set to 1/2/3 to stop at that level and fail if it doesn't succeed
# MAX_FETCH_LEVEL=1

# Search Engine (optional, for L3 fallback)
SEARCH_API_KEY=
GOOGLE_CX=
