# ------ Required ------

# Authentication
API_KEY=sk-snapmind-xxxxxxxxxxxx
JWT_SECRET=your-jwt-secret-here

# LLM provider — global switch for both VLM and processor calls.
# Supported: openrouter | local
#   - openrouter: hosted, requires OPENROUTER_API_KEY
#   - local: any OpenAI-compatible local server (LM Studio, vLLM, Ollama, llama.cpp, …)
LLM_PROVIDER_TARGET=openrouter

# OpenRouter (required when LLM_PROVIDER_TARGET=openrouter)
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxx



# ------ Optional ------

# Obsidian Vault (defaults to macOS iCloud Drive/Obsidian)
OBSIDIAN_VAULT_PATH=
# Obsidian screenshot display width in generated notes
OBSIDIAN_SCREENSHOT_WIDTH=360

# OpenRouter models (optional, defaults shown)
OPENROUTER_VLM_MODEL=moonshotai/kimi-k2.5
OPENROUTER_PROCESSOR_MODEL=moonshotai/kimi-k2.5

# Local provider (required when LLM_PROVIDER_TARGET=local).
# Default base URL is LM Studio's port; override for vLLM (:8000/v1), Ollama (:11434/v1), etc.
LOCAL_BASE_URL=http://localhost:1234/v1
LOCAL_API_KEY=local
# Set these to model IDs as reported by `GET <LOCAL_BASE_URL>/models`.
LOCAL_VLM_MODEL=
LOCAL_PROCESSOR_MODEL=

# Fetch level limit (optional, 1-4, default 4)
# Set to 1/2/3 to stop at that level and fail if it doesn't succeed
MAX_FETCH_LEVEL=4

# Batch upload (optional)
MAX_BATCH_SIZE=50
MAX_CONCURRENT_PIPELINES=5

# Rate limit (optional)
# Per Bearer token (or IP if no auth header). Single-user deploy, so this
# is mainly to stop runaway scripts — not DDoS mitigation.
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute

# Search Engine (optional, for L3 fallback)
SEARCH_API_KEY=
GOOGLE_CX=
