{
  "name": "snap-mind",
  "version": "0.1.0",
  "description": "截图即收藏：从截图到结构化知识库的自动化管道",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/js-levenshtein": "1.1.3",
    "@types/node": "22.19.17",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "dependencies": {
    "@fastify/multipart": "9.4.0",
    "dayjs": "1.11.20",
    "dotenv": "16.6.1",
    "fastify": "5.8.4",
    "gray-matter": "4.0.3",
    "js-levenshtein": "1.1.6",
    "nanoid": "5.1.7",
    "openai": "4.104.0",
    "pino": "10.3.1",
    "playwright": "1.59.1",
    "slugify": "1.6.9"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  }
}
