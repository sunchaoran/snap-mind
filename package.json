{
  "name": "snap-mind",
  "version": "0.3.0",
  "description": "截图即收藏：从截图到结构化知识库的自动化管道",
  "type": "module",
  "bin": {
    "snap-mind": "dist/cli.js"
  },
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.2",
      "postcss": ">=8.5.10"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/js-levenshtein": "1.1.3",
    "@types/node": "24.12.2",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.5",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@fastify/multipart": "10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "dayjs": "1.11.20",
    "fastify": "5.8.5",
    "fastify-plugin": "5.1.0",
    "gray-matter": "4.0.3",
    "js-levenshtein": "1.1.6",
    "nanoid": "5.1.9",
    "openai": "6.34.0",
    "pino": "10.3.1",
    "playwright": "1.59.1",
    "semver": "7.7.4",
    "sharp": "0.34.5"
  },
  "scripts": {
    "prepare": "git config --local core.hooksPath .githooks || true",
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "cli": "node --import tsx cli/snap-mind-cli/main.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "lint:fix-unsafe": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "check:opencli": "node --import tsx scripts/check-opencli.ts",
    "gen:api-doc": "node --import tsx scripts/gen-api-doc.ts"
  }
}
