{
  "name": "snap-mind",
  "version": "0.2.1",
  "description": "截图即收藏：从截图到结构化知识库的自动化管道",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/js-levenshtein": "1.1.3",
    "@types/node": "24.12.2",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.5",
    "pino-pretty": "13.1.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  },
  "dependencies": {
    "@fastify/multipart": "9.4.0",
    "dayjs": "1.11.20",
    "fastify": "5.8.5",
    "gray-matter": "4.0.3",
    "js-levenshtein": "1.1.6",
    "nanoid": "5.1.7",
    "openai": "4.104.0",
    "pino": "10.3.1",
    "playwright": "1.59.1",
    "semver": "7.7.4",
    "sharp": "0.34.5"
  },
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsup",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "lint:fix-unsafe": "biome check --fix --unsafe .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.2",
      "postcss": ">=8.5.10"
    }
  }
}
